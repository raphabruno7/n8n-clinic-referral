# ── Google ────────────────────────────────────────────────────────────────────
# Google Sheets document ID (found in the Sheet URL)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── Microsoft SharePoint ───────────────────────────────────────────────────────
# SharePoint site ID — get via: GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{site-path}
SHAREPOINT_SITE_ID=your_sharepoint_site_id_here

# Drive ID within the SharePoint site
# GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives
SHAREPOINT_DRIVE_ID=your_sharepoint_drive_id_here

# Item IDs for each Word template uploaded to SharePoint
# GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives/{drive-id}/root/children
TEMPLATE_ID_5S=sharepoint_item_id_for_5_sessions_template
TEMPLATE_ID_10S=sharepoint_item_id_for_10_sessions_template
TEMPLATE_ID_15S=sharepoint_item_id_for_15_sessions_template
TEMPLATE_ID_20S=sharepoint_item_id_for_20_sessions_template

# ── Notes ─────────────────────────────────────────────────────────────────────
# These variables are referenced in n8n via {{ $env.VARIABLE_NAME }}
# Set them in n8n Settings → Environment Variables (Settings > Variables)
# Do NOT commit the filled .env file — add it to .gitignore
