    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Fill placeholders in Word .docx XML\n// The .docx binary comes from the previous HTTP Request node\n// We manipulate the XML inside the ZIP to replace {{PLACEHOLDER}} tokens\n\nconst JSZip = require('jszip');\n\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  // Get the binary docx file\n  const binaryKey = Object.keys(item.binary || {})[0];\n  if (!binaryKey) throw new Error('No binary data found in template node output');\n\n  const docxBuffer = Buffer.from(item.binary[binaryKey].data, 'base64');\n\n  // Get patient data from the trigger node\n  const patient = $('Google Sheets Trigger').first().json;\n  const centro   = $('Lookup Centro Email').first().json;\n\n  const placeholders = {\n    '{{NOMBRE_PACIENTE}}':  patient.nombre_paciente  || '',\n    '{{NUMERO_HISTORIA}}':  patient.numero_historia  || '',\n    '{{EXPEDIENTE}}':       patient.expediente       || '',\n    '{{NUMERO_SS}}':        patient.numero_ss        || '',\n    '{{CENTRO_DERIVADO}}':  centro.nombre            || patient.centro_id,\n    '{{FECHA}}':            patient.fecha            || new Date().toLocaleDateString('es-ES'),\n    '{{NUMERO_SESIONES}}':  String(patient.numero_sesiones || ''),\n    '{{DIAGNOSTICO}}':      patient.diagnostico      || '',\n    '{{MEDICO_REMITENTE}}': patient.medico_remitente || '',\n    '{{ESPECIALIDAD}}':     patient.especialidad     || '',\n    '{{TELEFONO_PACIENTE}}':patient.telefono_paciente|| '',\n    '{{FECHA_NACIMIENTO}}': patient.fecha_nacimiento || '',\n    '{{OBSERVACIONES}}':    patient.observaciones    || 'Sin observaciones.',\n  };\n\n  // Unzip, replace in word/document.xml, rezip\n  const zip = await JSZip.loadAsync(docxBuffer);\n  let xml = await zip.file('word/document.xml').async('string');\n\n  for (const [key, value] of Object.entries(placeholders)) {\n    // Escape for XML and also handle split-tag placeholders\n    xml = xml.split(key).join(value);\n  }\n\n  zip.file('word/document.xml', xml);\n  const filledBuffer = await zip.generateAsync({ type: 'nodebuffer', compression: 'DEFLATE' });\n\n  results.push({\n    json: { ...patient, centro_email: centro.email },\n    binary: {\n      data: {\n        data: filledBuffer.toString('base64'),\n        mimeType: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',\n        fileName: `referral_${patient.numero_historia}.docx`,\n      }\n    }\n  });\n}\n\nreturn results;"
      },
